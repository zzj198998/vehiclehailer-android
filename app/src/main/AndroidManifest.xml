<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.egogame.vehiclehailer">

    <!-- 读取系统日志（CAN信号监听必需） -->
    <uses-permission android:name="android.permission.READ_LOGS" />
    <!-- 录音权限（语音识别/TTS备用 + 实时喊话） -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 网络访问（TTS在线生成接口） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 后台通知栏播放 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 防止休眠 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 外放声道控制 -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".VehicleHailerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VehicleHailer"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:theme="@style/Theme.VehicleHailer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 后台服务用于保持logcat监听 -->
        <service
            android:name=".engine.LogcatService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- 录音服务（前台Service，支持实时喊话和录音保存） -->
        <service
            android:name=".service.AudioRecordService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

    </application>

</manifest>
