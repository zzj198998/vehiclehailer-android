<?xml version="1.0" encoding="utf-8"?>
<!--
  车机横屏自适应布局
  侧边栏 <-> 内容区 = 1:6
  深色侧边栏 + 白色主内容区
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background">

    <!-- ========== 左侧深色侧边栏 ========== -->
    <LinearLayout
        android:id="@+id/nav_sidebar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/background_sidebar"
        android:paddingTop="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:elevation="4dp">

        <!-- Logo区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5"
            android:gravity="center"
            android:text="🚗"
            android:textSize="24sp" />

        <!-- App名称 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="#FFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="28dp"
            android:layout_height="1dp"
            android:background="#FF4B5563"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- 5个导航按钮 -->
        <TextView
            android:id="@+id/nav_voice"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:drawableTop="@android:drawable/ic_media_play"
            android:drawablePadding="3dp"
            android:text="@string/tab_voice"
            android:textColor="@color/primary_light"
            android:textSize="10sp"
            android:background="@drawable/sidebar_item_selected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/nav_monitor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:drawableTop="@android:drawable/ic_menu_info_details"
            android:drawablePadding="3dp"
            android:text="@string/tab_monitor"
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/nav_trigger"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:drawableTop="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="3dp"
            android:text="@string/tab_trigger"
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/nav_audio_library"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:drawableTop="@android:drawable/ic_menu_gallery"
            android:drawablePadding="3dp"
            android:text="@string/nav_audio_library"
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:drawableTop="@android:drawable/ic_menu_preferences"
            android:drawablePadding="3dp"
            android:text="@string/tab_settings"
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true" />

        <!-- 版本号 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="v1.0"
            android:textColor="#FF6B7280"
            android:textSize="9sp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- 右侧白色内容区 -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="6" />

</LinearLayout>
