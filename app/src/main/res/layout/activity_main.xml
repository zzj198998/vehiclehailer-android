<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFF9FAFB">

    <!-- ========== 左侧导航栏（70dp固定宽度，白底） ========== -->
    <LinearLayout
        android:id="@+id/nav_sidebar"
        android:layout_width="70dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFFFF"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <!-- Logo区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="📢"
            android:textSize="26sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="喊话器"
            android:textColor="#FF1F2937"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <View
            android:layout_width="28dp"
            android:layout_height="1dp"
            android:background="#FFE5E7EB"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp" />

        <!-- 导航按钮 -->
        <LinearLayout
            android:id="@+id/nav_voice"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_selected"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#FF3B82F6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="喊话"
                android:textColor="#FF3B82F6"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_monitor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="📊"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="监控"
                android:textColor="#FF6B7280"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_trigger"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="📋"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="规则"
                android:textColor="#FF6B7280"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_audio_library"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="🎵"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音频库"
                android:textColor="#FF6B7280"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="⚙"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textColor="#FF6B7280"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 底部版本和状态 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="v1.0"
            android:textColor="#FF9CA3AF"
            android:textSize="8sp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/connection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="离线"
            android:textColor="#FFEF4444"
            android:textSize="8sp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE5E7EB" />

    <!-- 右侧内容区 -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#FFF9FAFB" />

</LinearLayout>
