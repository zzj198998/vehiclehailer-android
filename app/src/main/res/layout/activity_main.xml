<?xml version="1.0" encoding="utf-8"?>
<!--
  车机横屏HMI布局（已改版）
  左侧70dp白底导航 + 右侧内容区
  白底黑字 · 大图标大文字 · 蓝色选中竖条
  参考：鱼蛋语音积木横屏布局
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFF9FAFB">

    <!-- ========== 左侧白底导航栏（70dp固定宽度） ========== -->
    <LinearLayout
        android:id="@+id/nav_sidebar"
        android:layout_width="70dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFFFF"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:elevation="0dp">

        <!-- App名称/Logo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="🚗"
            android:textSize="28sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="喊话器"
            android:textColor="#FF1F2937"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:background="#FFE5E7EB"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- 导航按钮1：喊话（带drawableTop图标 + 文字） -->
        <LinearLayout
            android:id="@+id/nav_voice"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_selected"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="18sp"
                android:textColor="#FF3B82F6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="喊话"
                android:textColor="#FF3B82F6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 导航按钮2：监控 -->
        <LinearLayout
            android:id="@+id/nav_monitor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="📊"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="监控"
                android:textColor="#FF6B7280"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 导航按钮3：触发规则 -->
        <LinearLayout
            android:id="@+id/nav_trigger"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="📋"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="规则"
                android:textColor="#FF6B7280"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 导航按钮4：音频库 -->
        <LinearLayout
            android:id="@+id/nav_audio_library"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="🎵"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音频库"
                android:textColor="#FF6B7280"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 导航按钮5：设置 -->
        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/sidebar_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="⚙"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textColor="#FF6B7280"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 版本号 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="v1.0"
            android:textColor="#FF9CA3AF"
            android:textSize="9sp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- 左侧导航与内容区分割线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FFE5E7EB" />

    <!-- ========== 右侧内容区（白底） ========== -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#FFF9FAFB" />

</LinearLayout>
