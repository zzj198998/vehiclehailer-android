<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFF9FAFB"
    android:padding="12dp">

    <!-- 左侧：分类导航（白底、大间距） -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFE5E7EB"
        app:cardBackgroundColor="#FFFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/category_title"
                android:textColor="#FF1F2937"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tab_hailing"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/audio_tab_hailing"
                android:textColor="#FF1F2937"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/sidebar_item_selected" />

            <TextView
                android:id="@+id/tab_door"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/audio_tab_door"
                android:textColor="#FF6B7280"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/sidebar_item_normal" />

            <TextView
                android:id="@+id/tab_lock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/audio_tab_lock"
                android:textColor="#FF6B7280"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/sidebar_item_normal" />

            <TextView
                android:id="@+id/tab_custom"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/audio_tab_custom"
                android:textColor="#FF6B7280"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/sidebar_item_normal" />

            <TextView
                android:id="@+id/tab_soundwave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/audio_tab_soundwave"
                android:textColor="#FF6B7280"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/sidebar_item_normal" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 右侧：音频列表 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFE5E7EB"
        app:cardBackgroundColor="#FFFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 标题 + 上传按钮横排 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/audio_management_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FF1F2937" />

                <Button
                    android:id="@+id/btn_upload_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="@string/audio_upload"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    app:cornerRadius="22dp"
                    android:backgroundTint="#FF2563EB"
                    android:textColor="#FFFFFFFF" />
            </LinearLayout>

            <!-- 格式提示 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/audio_format_hint"
                android:textSize="13sp"
                android:textColor="#FF9CA3AF"
                android:layout_marginBottom="12dp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFE5E7EB"
                android:layout_marginBottom="8dp" />

            <!-- 空状态提示 -->
            <TextView
                android:id="@+id/audio_empty_hint"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/audio_empty_hint"
                android:textSize="16sp"
                android:textColor="#FF9CA3AF"
                android:visibility="visible" />

            <!-- 音频列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/audio_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>