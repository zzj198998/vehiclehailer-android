<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/audio_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FFE5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- 播放按钮 -->
        <ImageButton
            android:id="@+id/btn_play_audio"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/sidebar_item_normal"
            android:scaleType="center"
            android:contentDescription="@string/audio_playing"
            android:tint="#FF2563EB" />

        <!-- 音频名称 -->
        <TextView
            android:id="@+id/audio_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:textColor="#FF1F2937"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 重命名按钮 -->
        <ImageButton
            android:id="@+id/btn_rename"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:contentDescription="@string/audio_rename"
            android:tint="#FF6B7280" />

        <!-- 删除按钮 -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:contentDescription="@string/audio_delete"
            android:tint="#FF6B7280" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>