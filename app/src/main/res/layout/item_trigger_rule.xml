<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FFE5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- 规则信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 属性名 -->
            <TextView
                android:id="@+id/rule_property"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FF1F2937" />

            <!-- 条件（旧值→新值） -->
            <TextView
                android:id="@+id/rule_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#FF6B7280" />

            <!-- 音频信息 -->
            <TextView
                android:id="@+id/rule_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FF9CA3AF" />
        </LinearLayout>

        <!-- 启用/禁用开关 -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/rule_enable_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
