<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#FFFFFFFF"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FFE5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- 序号圆形（默认绿色，代码层根据状态切换背景：green=待播放、blue=播放中、orange=已阻塞） -->
        <TextView
            android:id="@+id/voice_id"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/circle_indicator_green"
            android:contentDescription="@string/voice_status_idle"
            tools:text="01" />

        <!-- 音效信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/voice_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF1F2937"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/voice_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="#FF9CA3AF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- 播放按钮 -->
        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_border"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@string/btn_play"
            android:tint="#FF2563EB"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btn_stop"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_border"
            android:src="@android:drawable/ic_media_pause"
            android:contentDescription="@string/btn_stop"
            android:tint="#FF9CA3AF"
            android:padding="8dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
