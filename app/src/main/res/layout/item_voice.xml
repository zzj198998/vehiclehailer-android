<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#FFFFFFFF"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FFE5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- 序号圆形 -->
        <TextView
            android:id="@+id/voice_id"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/circle_indicator_green" />

        <!-- 音效名称 -->
        <TextView
            android:id="@+id/voice_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="#FF1F2937"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 播放按钮 -->
        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/circle_border"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@string/btn_play"
            android:tint="#FF2563EB"
            android:padding="7dp" />

        <ImageButton
            android:id="@+id/btn_stop"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/circle_border"
            android:src="@android:drawable/ic_media_pause"
            android:contentDescription="@string/btn_stop"
            android:tint="#FF9CA3AF"
            android:padding="7dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
