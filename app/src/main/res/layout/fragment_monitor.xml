<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFF9FAFB"
    android:padding="12dp">

    <!-- 左侧：状态+属性列表 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFE5E7EB"
        app:cardBackgroundColor="#FFFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 连接状态指示（加大间距） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:paddingBottom="12dp">

                <View
                    android:id="@+id/connection_indicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/circle_indicator_red" />

                <TextView
                    android:id="@+id/connection_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/vehicle_disconnected"
                    android:textColor="#FF6B7280"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/update_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF9CA3AF"
                    android:textSize="13sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFE5E7EB" />

            <!-- 目录分类Chip（加大间距） -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingVertical="10dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/catalog_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacing="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/filter_all"
                        android:textSize="13sp"
                        android:textColor="#FF1F2937"
                        app:chipBackgroundColor="#FFF3F4F6"
                        app:chipStrokeColor="#FFE5E7EB"
                        app:chipStrokeWidth="0dp"
                        app:chipCornerRadius="18dp" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

            <!-- 属性列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/property_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 右侧：实时日志面板 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFE5E7EB"
        app:cardBackgroundColor="#FFFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/monitor_log_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF1F2937"
                android:paddingBottom="10dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFE5E7EB" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/monitor_log_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="10dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
