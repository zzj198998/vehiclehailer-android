<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0D0D0D"
    android:padding="16dp">

    <!-- 顶部：标题 + 版本号 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_voice"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.2.0"
            android:textColor="#FF666666"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 自定义音效 / 系统音效 Tab切换（使用ChipGroup保留功能） -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#FF1A1A1A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_custom"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/filter_custom"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFFF"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_system"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/filter_system"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFFF"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color" />

            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 搜索框 -->
    <LinearLayout
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FF1A1A1A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:hint="@string/search_voice_hint"
            android:textColorHint="#FF666666"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:background="#00000000"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:drawableTint="#FF666666" />
    </LinearLayout>

    <!-- 音效快捷列表 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="让让要吧"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="#FF2A2A2A"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="开快点"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="#FF2A2A2A"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="快点走吧"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="#FF2A2A2A"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="关远光灯"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:background="#FF2A2A2A" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 喊话控制区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <!-- 停止音频 -->
        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:background="@drawable/bg_btn_stop"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="■"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- 红色大圆形喊话 -->
        <LinearLayout
            android:id="@+id/btn_add_voice"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center"
            android:background="@drawable/bg_btn_shout"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="喊话"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 循环开关 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="24dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/loop_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:thumbTintMode="src_in"
                android:trackTint="#FF333333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="循环"
                android:textColor="#FFAAAAAA"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 语音列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/voice_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp" />

</LinearLayout>
