<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D0D0D"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ 顶部标题 ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ 系统设置"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- ═══ 区块①：车型配置 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="车型设置"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/car_model_spinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_background"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:popupBackground="#FF1A1A1A" />
        </LinearLayout>

        <!-- ═══ 区块②：音频流 &amp; 声道 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音频流 &amp; 声道"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="音频流类型"
                android:textColor="#FFAAAAAA"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/stream_type_spinner"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="内容类型"
                android:textColor="#FFAAAAAA"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/content_type_spinner"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#FF333333" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/channel_switch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:text="车内声道"
                android:textColor="#FFCCCCCC"
                android:textSize="14sp"
                android:checked="true"
                android:thumbTintMode="src_in"
                android:trackTint="#FF444444" />
        </LinearLayout>

        <!-- ═══ 区块③：增益控制 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="增益控制"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- TTS增益 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="TTS增益"
                    android:textColor="#FFAAAAAA"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/gain_tts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:max="150"
                    android:progress="100" />
                <TextView
                    android:id="@+id/gain_tts_text"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#FFCCCCCC"
                    android:textSize="11sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 喊话增益 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="喊话增益"
                    android:textColor="#FFAAAAAA"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/gain_hail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:max="150"
                    android:progress="100" />
                <TextView
                    android:id="@+id/gain_hail_text"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#FFCCCCCC"
                    android:textSize="11sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 录音增益 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="录音增益"
                    android:textColor="#FFAAAAAA"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/gain_record"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:max="150"
                    android:progress="100" />
                <TextView
                    android:id="@+id/gain_record_text"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#FFCCCCCC"
                    android:textSize="11sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 限幅器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="限幅器"
                    android:textColor="#FFAAAAAA"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/gain_limiter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:max="12"
                    android:progress="6" />
                <TextView
                    android:id="@+id/gain_limiter_text"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="-6dB"
                    android:textColor="#FFCCCCCC"
                    android:textSize="11sp"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ 区块④：TTS &amp; 自动触发 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TTS语音合成"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/tts_enabled_switch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="启用TTS"
                    android:textColor="#FFCCCCCC"
                    android:textSize="14sp"
                    android:thumbTintMode="src_in"
                    android:trackTint="#FF444444" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/auto_play_switch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="自动触发"
                    android:textColor="#FFCCCCCC"
                    android:textSize="14sp"
                    android:checked="true"
                    android:thumbTintMode="src_in"
                    android:trackTint="#FF444444" />
            </LinearLayout>

            <EditText
                android:id="@+id/tts_url_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:padding="10dp"
                android:hint="@string/setting_tts_url"
                android:text="https://app.sk3a.cn/tts/generate"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#FF666666"
                android:textSize="13sp"
                android:background="#FF2A2A2A" />
        </LinearLayout>

        <!-- ═══ 区块⑤：连接方式 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接方式"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ADB自连：无需配对自动连接"
                android:textColor="#FF888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/adb_cmd_self"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="#FF2A2A2A"
                android:textColor="#FF4ADE80"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="ADB连接其他车机："
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adb_cmd_other"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:padding="12dp"
                android:background="#FF2A2A2A"
                android:textColor="#FF4ADE80"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/adb_copied_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FF666666"
                android:textSize="11sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ═══ 版本号 ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="车机喊话系统 v1.2.0"
            android:textColor="#FF666666"
            android:textSize="12sp"
            android:gravity="center" />

        <!-- ══════════════════════════════════════════════════ -->
        <!-- 下面区域保持所有右栏控件ID可见性GONE，供Java代码findViewById使用 -->
        <!-- ══════════════════════════════════════════════════ -->

        <!-- 声道路由 - 喊话 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">

            <Spinner android:id="@+id/route_hailing_channel"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <Spinner android:id="@+id/route_door_channel"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <Spinner android:id="@+id/route_lock_channel"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <Spinner android:id="@+id/route_soundwave_channel"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <Spinner android:id="@+id/route_custom_channel"
                android:layout_width="match_parent" android:layout_height="wrap_content" />

            <SeekBar android:id="@+id/route_hailing_volume"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/route_door_volume"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/route_lock_volume"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/route_soundwave_volume"
                android:layout_width="match_parent" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/route_custom_volume"
                android:layout_width="match_parent" android:layout_height="wrap_content" />

            <TextView android:id="@+id/route_hailing_volume_text"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/route_door_volume_text"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/route_lock_volume_text"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/route_soundwave_volume_text"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/route_custom_volume_text"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_hailing_noise"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_door_noise"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_lock_noise"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_soundwave_noise"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_custom_noise"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_hailing_voice"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_door_voice"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_lock_voice"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_soundwave_voice"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/route_custom_voice"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
