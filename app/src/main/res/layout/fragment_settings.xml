<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background_dark">

    <!-- ===== 左栏：设置项 ===== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 车型选择 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_car_model"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <Spinner
                        android:id="@+id/car_model_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/spinner_background"
                        android:textColor="@color/white"
                        android:popupBackground="@color/background_card" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 声道切换 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_channel"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/channel_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/setting_channel_inside"
                        android:textColor="@color/white"
                        android:checked="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TTS设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_tts"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/tts_enabled_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/setting_tts_enabled"
                        android:textColor="@color/white" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary_light"
                        app:boxStrokeWidth="1dp"
                        app:hintTextColor="@color/gray_400"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tts_url_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/setting_tts_url"
                            android:text="https://app.sk3a.cn/tts/generate"
                            android:textColor="@color/white"
                            android:textColorHint="@color/gray_600" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 自动触发 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/auto_play_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_auto_play"
                        android:textColor="@color/white"
                        android:checked="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 连接方式 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/connection_obd"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/connection_obd_desc"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp"
                        android:lineSpacingExtra="3dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/connection_logcat"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/connection_logcat_desc"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp"
                        android:lineSpacingExtra="3dp" />
                    <TextView
                        android:id="@+id/adb_cmd_self"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="8dp"
                        android:background="@drawable/code_bg"
                        android:text="@string/connection_adb_cmd_self"
                        android:textColor="@color/code_text"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:clickable="true"
                        android:focusable="true" />
                    <TextView
                        android:id="@+id/adb_cmd_other"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:padding="8dp"
                        android:background="@drawable/code_bg"
                        android:text="@string/connection_adb_cmd_other"
                        android:textColor="@color/code_text"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:clickable="true"
                        android:focusable="true" />
                    <TextView
                        android:id="@+id/adb_copied_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/connection_adb_hint"
                        android:textColor="@color/gray_600"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 版本信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:text="\u8f66\u8f86\u558a\u8bdd\u5668 v1.0\n\u57fa\u4e8e\u542f\u6e90Q05\u9006\u5411\u5f00\u53d1"
                android:textColor="@color/gray_600"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

    <!-- 中部分隔线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/gray_800" />


    <!-- ===== 右栏：声道路由设置 ===== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/route_desc"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp" />

                    <!-- 1. 喊话输出 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/background_card_light"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/route_hailing"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/volume"
                                    android:textColor="@android:color/black"
                                    android:textSize="11sp"/>
                                <SeekBar
                                    android:id="@+id/route_hailing_volume"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginHorizontal="6dp"
                                    android:max="100"
                                    android:progress="80"/>
                                <TextView
                                    android:id="@+id/route_hailing_volume_text"
                                    android:layout_width="32dp"
                                    android:layout_height="wrap_content"
                                    android:text="80%"
                                    android:textColor="@android:color/black"
                                    android:textSize="10sp"
                                    android:gravity="end"/>
                            </LinearLayout>
                            <Spinner
                                android:id="@+id/route_hailing_channel"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="2dp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal">
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_hailing_noise"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/noise_reduction"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_hailing_voice"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/voice_enhance"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <!-- 2. 开关门音效 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/background_card_light"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/route_door"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/volume"
                                    android:textColor="@android:color/black"
                                    android:textSize="11sp"/>
                                <SeekBar
                                    android:id="@+id/route_door_volume"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginHorizontal="6dp"
                                    android:max="100"
                                    android:progress="60"/>
                                <TextView
                                    android:id="@+id/route_door_volume_text"
                                    android:layout_width="32dp"
                                    android:layout_height="wrap_content"
                                    android:text="60%"
                                    android:textColor="@android:color/black"
                                    android:textSize="10sp"
                                    android:gravity="end"/>
                            </LinearLayout>
                            <Spinner
                                android:id="@+id/route_door_channel"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="2dp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal">
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_door_noise"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/noise_reduction"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_door_voice"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/voice_enhance"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 3. 锁车解锁 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/background_card_light"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/route_lock"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/volume"
                                    android:textColor="@android:color/black"
                                    android:textSize="11sp"/>
                                <SeekBar
                                    android:id="@+id/route_lock_volume"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginHorizontal="6dp"
                                    android:max="100"
                                    android:progress="70"/>
                                <TextView
                                    android:id="@+id/route_lock_volume_text"
                                    android:layout_width="32dp"
                                    android:layout_height="wrap_content"
                                    android:text="70%"
                                    android:textColor="@android:color/black"
                                    android:textSize="10sp"
                                    android:gravity="end"/>
                            </LinearLayout>
                            <Spinner
                                android:id="@+id/route_lock_channel"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="2dp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal">
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_lock_noise"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/noise_reduction"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_lock_voice"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/voice_enhance"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 4. 模拟声浪 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/background_card_light"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/route_soundwave"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/soundwave_channel_hint"
                                android:textColor="@color/gray_600"
                                android:textSize="10sp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/volume"
                                    android:textColor="@android:color/black"
                                    android:textSize="11sp"/>
                                <SeekBar
                                    android:id="@+id/route_soundwave_volume"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginHorizontal="6dp"
                                    android:max="100"
                                    android:progress="50"/>
                                <TextView
                                    android:id="@+id/route_soundwave_volume_text"
                                    android:layout_width="32dp"
                                    android:layout_height="wrap_content"
                                    android:text="50%"
                                    android:textColor="@android:color/black"
                                    android:textSize="10sp"
                                    android:gravity="end"/>
                            </LinearLayout>
                            <Spinner
                                android:id="@+id/route_soundwave_channel"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="2dp"
                                android:enabled="false"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal">
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_soundwave_noise"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/noise_reduction"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_soundwave_voice"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/voice_enhance"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 5. 自定义音效 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/background_card_light"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/route_custom"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/volume"
                                    android:textColor="@android:color/black"
                                    android:textSize="11sp"/>
                                <SeekBar
                                    android:id="@+id/route_custom_volume"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginHorizontal="6dp"
                                    android:max="100"
                                    android:progress="60"/>
                                <TextView
                                    android:id="@+id/route_custom_volume_text"
                                    android:layout_width="32dp"
                                    android:layout_height="wrap_content"
                                    android:text="60%"
                                    android:textColor="@android:color/black"
                                    android:textSize="10sp"
                                    android:gravity="end"/>
                            </LinearLayout>
                            <Spinner
                                android:id="@+id/route_custom_channel"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="2dp"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal">
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_custom_noise"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/noise_reduction"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/route_custom_voice"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/voice_enhance"
                                    android:textSize="10sp"
                                    android:textColor="@android:color/black"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="\u6bcf\u4e2a\u97f3\u9891\u901a\u9053\u5747\u652f\u6301\u72ec\u7acb\u8c03\u8282\u97f3\u91cf\u3001\u964d\u566a\u548c\u4eba\u58f0\u589e\u5f3a"
                android:textColor="@color/gray_600"
                android:textSize="10sp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
